# ── Database ─────────────────────────────────────────────────────
POSTGRES_USER=inventory
POSTGRES_PASSWORD=inventory_secret
POSTGRES_DB=inventory_db
DATABASE_URL=postgresql+asyncpg://inventory:inventory_secret@db:5432/inventory_db

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-strong-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ──────────────────────────────────────────────────────────
APP_NAME=InventoryManager
APP_VERSION=1.0.0
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ── Stock adjustment threshold ───────────────────────────────────
ADJUSTMENT_THRESHOLD=10
